# Copy to `.env` for local development. `.env` is gitignored — never commit secrets.
# Values for the local stack are printed by `supabase start`.

# --- Supabase: public (safe to expose to the browser) ---
PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
PUBLIC_SUPABASE_ANON_KEY="<local-anon-key-from-supabase-start>"

# --- Supabase: server-only (NEVER expose to the client) ---
# Imported only under src/lib/server/** — enforced by the secret-guard test
# (tests/unit/no-service-role-leak.test.ts) and SvelteKit's $lib/server boundary.
SUPABASE_SERVICE_ROLE_KEY="<local-service-role-key-from-supabase-start>"

# --- Auth: Google sign-in (Step 1) ---
# Referenced by supabase/config.toml ([auth.external.google]); server-only.
SUPABASE_AUTH_GOOGLE_CLIENT_ID="<google-oauth-client-id>"
SUPABASE_AUTH_GOOGLE_SECRET="<google-oauth-client-secret>"

# --- Tests: database for the RLS / migration suites (Step 1) ---
# The DB test harness DROPS AND RECREATES the public schema, so point this at a
# DISPOSABLE database — never your dev data. CI provides a throwaway Postgres.
# Unset = the DB test suites skip (the rest of `pnpm test` still runs).
# Local stack example (after `createdb ... zine_test`):
#   postgresql://postgres:postgres@127.0.0.1:54322/zine_test
SUPABASE_DB_URL=""
